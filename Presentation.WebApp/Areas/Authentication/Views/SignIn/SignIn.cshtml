@model SignInForm
@{
    Layout = "Layouts/_AuthLayout";
    ViewData["Title"] = "Sign In";
}

<section class="section__auth">
    <div class="title">
        <h1>Welcome Back!</h1>
        <p>Log in to continue your fitness journey with full access to your customized program, training history, and progress tracking. 
            Stay consistent, monitor your development, and keep moving forward with the structure and support built into your account.</p>
    </div>

    <hr />

    <form id="signInForm" method="post" asp-area="Authentication" asp-controller="SignIn" asp-action="SignIn" novalidate>
        @Html.AntiForgeryToken()

        <div class="form-group">
            <label class="form-label" asp-for="Email"></label>
            <div class="form-input-validation">
                <input class="form-input" asp-for="Email" autocomplete="off" />
                <span asp-validation-for="Email"></span>
            </div>
        </div>

        <div class="form-group">
            <label class="form-label" asp-for="Password"></label>
            <div class="form-input-validation">
                <input class="form-input" asp-for="Password" autocomplete="off" />
                <span asp-validation-for="Password"></span>
            </div>
        </div>

        <div data-type="terms" class="form-group checkbox">
            <div class="form-checkbox-validation">
                <label class="form-checkbox-label">
                    <input class="form-checkbox-input" asp-for="RememberMe" />
                    <span class="form-checkbox-checkmark"></span>
                    <label class="checkbox-label" asp-for="RememberMe"></label>
                </label>
                <span asp-validation-for="RememberMe"></span>
            </div>
        </div>

        <button class="btn" type="submit">Continue</button>

        <div class="form-errormessage">
            <span class="field-validation-error" asp-validation-for="ErrorMessage"></span>
        </div>

        <div asp-validation-summary="ModelOnly"></div>
        <input type="hidden" name="returnUrl" value="@ViewBag.ReturnUrl" />
    </form>
</section>

@section Scripts {
    <partial name="Partials/Common/_ValidationScripts" />
}