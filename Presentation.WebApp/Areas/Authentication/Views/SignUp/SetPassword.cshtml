@model SetPasswordForm
@{
    Layout = "Layouts/_AuthLayout";
    ViewData["Title"] = "Set Password";
}

<section class="section__auth">
    <div class="title">
        <h1>Set Your Password</h1>
        <p>Set a strong password to protect your account. For security reasons, your password must be at least 8 characters long and include uppercase and lowercase letters, numbers, and special characters.</p>
    </div>
        
    <hr />

    <form id="setPasswordForm" method="post" asp-area="Authentication" asp-controller="SignUp" asp-action="SetPassword" novalidate>
        @Html.AntiForgeryToken()

        <div class="form-group">
            <label class="form-label" asp-for="Password"></label>
            <div class="form-input-validation">
                <input class="form-input" asp-for="Password" />
                <span asp-validation-for="Password"></span>
            </div>
        </div>

        <div class="form-group">
            <label class="form-label" asp-for="ConfirmPassword"></label>
            <div class="form-input-validation">
                <input class="form-input" asp-for="ConfirmPassword" />
                <span asp-validation-for="ConfirmPassword"></span>
            </div>
        </div>

        <button class="btn" type="submit">Continue</button>
        
        <div class="form-errormessage">
            <span class="field-validation-error" asp-validation-for="ErrorMessage"></span>
        </div>

        <div asp-validation-summary="ModelOnly"></div>
        <input type="hidden" name="returnUrl" value="@ViewBag.ReturnUrl" />
    </form>

</section>

@section Scripts {
    <partial name="Partials/Common/_ValidationScripts" />

    <script>
        $(function () {
            const form = $("#setPasswordForm");

            console.log("validator finns?", !!form.data("validator"));
            console.log("unobtrusive finns?", !!form.data("unobtrusiveValidation"));

            form.on("submit", function (e) {
                const isValid = form.valid();
                console.log("form.valid() =", isValid);

                if (!isValid) {
                    e.preventDefault();
                    e.stopImmediatePropagation();
                }
            });
        });
    </script>
}