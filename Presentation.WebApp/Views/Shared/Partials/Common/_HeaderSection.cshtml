<section class="section__header">
    <div class="logotype">
        <a href="/"><img src="~/images/logotype.png" alt="CoreFitness Logotype" /></a>
    </div>
    <nav class="main-menu">
        <ul class="menu">
            <li class="menu-item">
                <a class="menu-item-link" asp-action="Index" asp-controller="FitnessCenters">Fitness Centers</a>
            </li>
            <li class="menu-item">
                <a class="menu-item-link" asp-action="Index" asp-controller="Memberships">Memberships</a>
            </li>
            <li class="menu-item">
                <a class="menu-item-link" asp-action="Index" asp-controller="Training">Training</a>
            </li>
            <li class="menu-item">
                <a class="menu-item-link" asp-action="Index" asp-controller="CustomerService">Customer Service</a>
            </li>
            <li class="menu-item">
                <a class="menu-item-link" asp-action="Index" asp-controller="Store">Store</a>
            </li>
        </ul>
    </nav>
    <nav class="account-menu">
        <ul class="menu">
            @if (User.Identity?.IsAuthenticated == true)
            {
                <li class="menu-item">
                    <form class="menu-item-form" method="post" asp-area="Account" asp-controller="Account" asp-action="SignOut">
                        @Html.AntiForgeryToken()
                        <button class="menu-item-link" type="submit">Sign Out</button>
                    </form>
                </li>
                <li class="menu-item">
                    <a class="btn accent" asp-area="Account" asp-controller="Account" asp-action="Index">My Account</a>
                </li>
            }
            else
            {
                <li class="menu-item">
                    <a class="menu-item-link" asp-area="Authentication" asp-controller="SignUp" asp-action="GetStarted">Become Member</a>
                </li>

                <li class="menu-item">
                    <a class="btn accent" asp-area="Authentication" asp-controller="SignIn" asp-action="SignIn">Sign In</a>
                </li>
            }
        </ul>
    </nav>

    <button id="mobile-menu-button" data-target="#mobile-menu-flyout" class="mobile-btn accent" aria-expanded="false" aria-controls="mobile-menu-flyout" aria-label="Toggle navigation menu"></button>
</section>

<nav id="mobile-menu-flyout" class="mobile-menu-flyout" aria-hidden="true">
    <ul class="menu">
        <li class="menu-item">
            <a class="menu-item-link" asp-action="Index" asp-controller="FitnessCenters">Fitness Centers</a>
        </li>
        <li class="menu-item">
            <a class="menu-item-link" asp-action="Index" asp-controller="Memberships">Memberships</a>
        </li>
        <li class="menu-item">
            <a class="menu-item-link" asp-action="Index" asp-controller="Training">Training</a>
            </li>
        <li class="menu-item">
            <a class="menu-item-link" asp-action="Index" asp-controller="CustomerService">Customer Service</a>
            </li>
        <li class="menu-item">
            <a class="menu-item-link" asp-action="Index" asp-controller="Store">Store</a>
            </li>
        @if (User.Identity?.IsAuthenticated == true)
        {
            <li class="menu-item">
                <form class="menu-item-form" method="post" asp-area="Account" asp-controller="Account" asp-action="SignOut">
                    @Html.AntiForgeryToken()
                    <button class="menu-item-link" type="submit">Sign Out</button>
                </form>
            </li>
            <li class="menu-item">
                <a class="btn accent" asp-area="Account" asp-controller="Account" asp-action="Index">My Account</a>
            </li>
        }
        else
        {
            <li class="menu-item">
                <a class="menu-item-link" asp-area="SignUp" asp-controller="Authentication">Become Member</a>
            </li>

            <li class="menu-item">
                <a class="btn accent" asp-area="SignIn" asp-controller="Authentication">Sign In</a>
            </li>
        }
    </ul>
</nav>