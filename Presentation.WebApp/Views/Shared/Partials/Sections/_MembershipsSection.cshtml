<section class="memberships-section">
    <div class="container">
        <div class="memberships-area">
            <div class="memberships-grid">

                <div class="membership-card">
                    <div class="top-icon"></div>

                    <h3>Standard Membership</h3>
                    <hr />
                    <p class="desc">With the Standard Membership, get access to our full range of gym facilities. </p>

                    <ul class="features">
                        <li>Standard Locker</li>
                        <li>High-energy group fitness classes</li>
                        <li>Motivating & supportive environment</li>
                    </ul>

                    <div class="price-box">
                        <div class="price-row">
                            <div class="price-left">
                                <div class="price">495.00 <span>/monthly</span></div>
                                <div class="classes">* Monthly 20 Classes</div>
                            </div>
                            <a class="btn" asp-area="Authentication" asp-controller="SignUp" asp-action="GetStarted">Join Now</a>
                        </div>
                        <hr />
                        <p class="note">Try Any Membership Free for 1 Week</p>
                    </div>
                </div>

                <div class="membership-card">
                    <div class="top-icon"></div>

                    <h3>Premium Membership</h3>
                    <hr />
                    <p class="desc">With the Premium Membership, get access to our full range of gym facilities. </p>

                    <ul class="features">
                        <li>Priority Support & Premium Locker</li>
                        <li>High-energy group fitness classes</li>
                        <li>Motivating & supportive environment</li>
                    </ul>

                    <div class="price-box">
                        <div class="price-row">
                            <div class="price-left">
                                <div class="price">595.00 <span>/monthly</span></div>
                                <div class="classes">* Monthly 20 Classes</div>
                            </div>
                            <a class="btn" asp-area="Authentication" asp-controller="SignUp" asp-action="GetStarted">Join Now</a>
                        </div>
                        <hr />
                        <p class="note">Try Any Membership Free for 1 Week</p>
                    </div>
                </div>

                <div class="membership-cta">
                    <h3>Get Your Membership</h3>
                    <p>Our memberships give you access to all equipment, personalized training.</p>
                    <hr />

                    <div class="phone">Call Us At: +(46) 8 410 521 00</div>

                    <button class="btn">Call Us Today!</button>

                    <img src="~/images/membership-image.png" alt="Girl working out" />
                </div>

            </div>

            <div class="membership-footer">
                <div class="footer-item trial">Get 30 day free trial</div>
                <div class="footer-item fees">No any hidden fees pay</div>
                <div class="footer-item cancel">You can cancel anytime</div>
            </div>
        </div>
    </div>
</section>
